# Environment configuration for Hatch Bot

# Base URL of your deployment. Required for NextAuth callbacks
NEXTAUTH_URL=http://localhost:3000

# Secret used to encrypt NextAuth sessions. Generate a secure random string in production
NEXTAUTH_SECRET=change-me

# MongoDB connection string. Replace with your own MongoDB Atlas connection URI
MONGODB_URI=mongodb://localhost:27017/hatchbot

# OAuth credentials obtained from the Discord Developer Portal
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Base URL for the Hatch AI chat API
HATCH_API_BASE=https://api.thehatch.store/api/chat